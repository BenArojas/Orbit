{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "parallax-backend", "sidecar": true }
      ]
    },
    "shell:allow-stdin-write",
    "process:allow-exit",
    "notification:default"
  ]
}
